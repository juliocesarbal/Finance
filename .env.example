# Copiar a .env y ajustar valores
DEBUG=True
SECRET_KEY=cambiame-por-una-clave-secreta-larga
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos (docker compose levanta TimescaleDB en 5432)
DATABASE_URL=postgres://finance:finance@localhost:5432/finance
# Sin Docker todavía: comentar la línea anterior y descomentar esta
# DATABASE_URL=sqlite:///db.sqlite3

# Redis: caché + broker Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
# Sin Redis todavía: descomentar para usar caché en memoria del proceso
# CACHE_URL=locmemcache://

# CORS (frontend Next.js)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Agente de verificación (sección 5.2) — opcional hasta usarlo en vivo
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-opus-4-8
AGENT_TOP_N=10
AGENT_SCORE_THRESHOLD=65

# Universo/watchlist inicial (tickers separados por coma, formato yfinance)
WATCHLIST=AAPL,MSFT,NVDA,TSLA,SPY,VOO,QQQ,BTC-USD,ETH-USD,SOL-USD
